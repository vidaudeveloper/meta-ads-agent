# =============================================================================
# meta-ads-agent profile 环境变量
# 复制本文件为 .env 并填写
# =============================================================================

# 模型推理（必填）
TOKENWARE_API_KEY=

# 与 TOKENWARE 相同时可省略
# OPENAI_API_KEY=

# 远程 MCP（正式环境默认；测试改为 meta-ads-agent.vidau.info）
ADS_AGENT_MCP_URL=https://meta-ads-agent.vidau.ai/mcp
ADS_AGENT_API_URL=https://meta-ads-agent.vidau.ai

# VidAU 桌面端自动注入，通常无需手填
# VIDAU_SSO_TOKEN=
